# Copy this file to .env.local and fill in your local values.
# .env.local is gitignored and is the shared config source for Docker Compose and backend settings.

# Postgres credentials for local development
POSTGRES_DB=neurobloom_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Backend runtime
POSTGRES_HOST=localhost
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080

# Optional overrides
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/neurobloom_db
# API_BASE_URL=http://localhost:8000
# SQL_ECHO=false
# DB_STARTUP_MAX_ATTEMPTS=20
# DB_STARTUP_RETRY_SECONDS=2
